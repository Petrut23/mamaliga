generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  predictions     Prediction[]
  badges          UserBadge[]
  roundRankings   RoundRanking[]
  overallRankings OverallRanking[]
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model Season {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  rounds          Round[]
  overallRankings OverallRanking[]
}

model Round {
  id          String      @id @default(cuid())
  seasonId    String
  roundNumber Int
  title       String
  deadlineAt  DateTime
  status      RoundStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  season        Season         @relation(fields: [seasonId], references: [id])
  matches       Match[]
  roundRankings RoundRanking[]
}

enum RoundStatus {
  DRAFT
  OPEN
  LOCKED
  LIVE
  COMPLETED
}

model Match {
  id              String      @id @default(cuid())
  roundId         String
  externalApiId   String?
  provider        String?
  competitionName String
  homeTeam        String
  awayTeam        String
  kickoffAt       DateTime
  status          MatchStatus @default(SCHEDULED)
  liveHomeScore   Int?
  liveAwayScore   Int?
  finalHomeScore  Int?
  finalAwayScore  Int?
  lastSyncedAt    DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  round       Round        @relation(fields: [roundId], references: [id])
  predictions Prediction[]
  matchPoints MatchPoint[]
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELED
}

model Prediction {
  id            String    @id @default(cuid())
  userId        String
  matchId       String
  predictedHome Int
  predictedAway Int
  isCaptain     Boolean   @default(false)
  submittedAt   DateTime  @default(now())
  lockedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  match       Match        @relation(fields: [matchId], references: [id])
  matchPoints MatchPoint[]

  @@unique([userId, matchId])
}

model MatchPoint {
  id                   String    @id @default(cuid())
  predictionId         String
  matchId              String
  basePoints           Int       @default(0)
  multiplier           Int       @default(1)
  totalPoints          Int       @default(0)
  isLive               Boolean   @default(false)
  isFinal              Boolean   @default(false)
  evaluatedAgainstHome Int?
  evaluatedAgainstAway Int?
  evaluatedAt          DateTime?

  prediction Prediction @relation(fields: [predictionId], references: [id])
  match      Match      @relation(fields: [matchId], references: [id])

  @@unique([predictionId, matchId])
}

model RoundRanking {
  id                String   @id @default(cuid())
  roundId           String
  userId            String
  confirmedPoints   Int      @default(0)
  provisionalPoints Int      @default(0)
  totalLivePoints   Int      @default(0)
  finalPoints       Int?
  exactHits         Int      @default(0)
  goalDiffHits      Int      @default(0)
  resultHits        Int      @default(0)
  captainPoints     Int      @default(0)
  rank              Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  round Round @relation(fields: [roundId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([roundId, userId])
}

model OverallRanking {
  id            String   @id @default(cuid())
  seasonId      String
  userId        String
  totalPoints   Int      @default(0)
  exactHits     Int      @default(0)
  goalDiffHits  Int      @default(0)
  resultHits    Int      @default(0)
  captainPoints Int      @default(0)
  roundsPlayed  Int      @default(0)
  averagePoints Float    @default(0)
  rank          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  season Season @relation(fields: [seasonId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([seasonId, userId])
}
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badge     String
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, badge])
}